  steps:
  - function: ShowCastMessage
    args:
    - "\u30C6\u30F3"
    - "\u2026\u2026\u2026\u2026\u3002"
  - function: ShowCastMessage
    args:
    - "\u30C6\u30F3"
    - "\u9B54\u529B\u66B4\u8D70\u306F\u4E88\u671F\u3057\u3066\u3044\u305F\u304C\u3001\n\u307E\u3055\u304B\u3053\u308C\u307B\u3069\u307E\u3067\u306B\u65E9\u3044\u3068\u306F\u3002"
  - function: ShowCastMessage
    args:
    - "\u30C6\u30F3"
    - "\u4E00\u5E2F\u306E\u96F7\u306F\u541B\u306E\u4ED5\u696D\u304B\u3044\uFF1F"
  - function: ShowCastMessage
    args:
    - "\u30A2\u30BA\u30DE"
    - "\u2026\u2026\u30A2\u30F3\u30BF\u8AB0\u3060\uFF1F\u3069\u3053\u304B\u3089\u6765\u305F\uFF1F\n\u305D\u306E\u901A\u308A\uFF01\u3053\u306E\u96F7\u306F\u30AA\u30EC\u306E\u9B54\u6CD5\u3060\uFF01"
  - function: ShowCastMessage
    args:
    - "\u30A2\u30BA\u30DE"
    - "\u30AA\u30EC\u3001\u3044\u307E\u30D3\u30C3\u30AF\u30EA\u3059\u308B\u304F\u3089\u3044\n\u9B54\u6CD5\u306E\u8ABF\u5B50\u304C\u826F\u304F\u3066\u3055\u3002"
  - function: ShowCastMessage
    args:
    - "\u30A2\u30BA\u30DE"
    - "\u3053\u308C\u4EE5\u4E0A\u8FD1\u4ED8\u304B\u308C\u308B\u3068\u3001\u30A2\u30F3\u30BF\u3092\n\u30B1\u30AC\u3055\u305B\u3061\u3083\u3046\u3088\u3046\u306A\u6C17\u304C\u3059\u308B\u3093\u3060\u3051\u3069\u3002"
  - function: ShowCastMessage
    args:
    - "\u30C6\u30F3"
    - "\"\u516B\u5366\u306E\u62C5\u3044\u624B\"\u306A\u306E\u306B\u3001\n\u9B54\u6CD5\u306E\u5236\u5FA1\u304C\u51FA\u6765\u3066\u3044\u306A\u3044\u2026\u2026\uFF1F"
  - function: ShowCastMessage
    args:
    - "\u30A2\u30BA\u30DE"
    - "\u2026\u2026\u30A2\u30F3\u30BF\u3001\u3044\u307E\u30AA\u30EC\u306E\u3053\u3068\u3092\n\u534A\u4EBA\u524D\u6271\u3044\u3057\u3084\u304C\u3063\u305F\u304B\uFF01\uFF1F"
  - function: ShowCastMessage
    args:
    - "\u30A2\u30BA\u30DE"
    - "\u78BA\u304B\u306B\u30AA\u30EC\u306F\u4ED6\u306E\u30E4\u30C4\u3089\u3068\u6BD4\u3079\u308B\u3068\n\u719F\u7DF4\u5EA6\u306F\u52A3\u308B\u304B\u3082\u3057\u308C\u306A\u3044\u3002"
  - function: ShowCastMessage
    args:
    - "\u30A2\u30BA\u30DE"
    - "\u3051\u3069\u3001\u51FA\u529B\u3067\u306F\u8AB0\u306B\u3082\u8CA0\u3051\u306D\u3048\uFF01\n\u8AB0\u304B\u77E5\u3089\u306D\u3048\u304C\u3001\u3053\u306E\u96F7\u306E\u9306\u306B\u3057\u3066\u3084\u308B\u305C\uFF01"
  - function: ShowCastMessage
    args:
    - "\u30C6\u30F3"
    - "\u3059\u307E\u306A\u3044\u3001\u6C7A\u3057\u3066\u717D\u308B\u3088\u3046\u306A\u3001\n\u305D\u3046\u3044\u3046\u3064\u3082\u308A\u3067\u306F\u306A\u304B\u3063\u305F\u306E\u3060\u304C\u2026\u2026\u3002"
  - function: ShowCastMessage
    args:
    - "\u30C6\u30F3"
    - "\u52DD\u8CA0\u306B\u306A\u308B\u306E\u306F\u90FD\u5408\u304C\u3044\u3044\u3002\n\u5236\u5727\u3055\u305B\u3066\u3044\u305F\u3060\u304F\u3088\u3002"

  steps:
  - function: ShowCastMessage
    args:
    - "\u30A2\u30BA\u30DE"
    - "\u2026\u2026\u96FB\u6C60\u5207\u308C\u3060\u3002\n\u3082\u3046\u52D5\u3051\u306D\u3047\u2026\u2026\uFF01"
  - function: ShowCastMessage
    args:
    - "\u30A2\u30BA\u30DE"
    - "\u3055\u3063\u304D\u306F\u6025\u306B\u9B54\u6CD5\u30D6\u30C3\u98DB\u3070\u3057\u3066\u60AA\u3043\u306A\u2026\u2026\u3002\n\u52A9\u304B\u3063\u305F\u3088\u3001\u30A2\u30F3\u30BF\u4F55\u8005\u3060\uFF1F"
  - function: ShowCastMessage
    args:
    - "\u30C6\u30F3"
    - "\u30C6\u30F3\u3002\u592A\u967D\u306E\u56FD\u306E\"\u516B\u5366\u306E\u62C5\u3044\u624B\"\u306E\u8005\u3060\u3002\n\u3053\u3061\u3089\u3053\u305D\u8AAC\u660E\u4E0D\u8DB3\u3067\u3059\u307E\u306A\u3044\u3002"
  - function: ShowCastMessage
    args:
    - "\u30C6\u30F3"
    - "\u3044\u307E\u4E16\u754C\u306B\u7570\u5E38\u304C\u8D77\u304D\u3066\u3044\u308B\u3002\n\u304A\u305D\u3089\u304F\u306F\u9B54\u529B\u306E\u66B4\u8D70\u3002"
  - function: ShowCastMessage
    args:
    - "\u30C6\u30F3"
    - "\u5148\u307B\u3069\u5225\u306E\u8005\u3068\u5BFE\u5CD9\u3057\u305F\u3068\u304D\u306F\n\u3053\u3053\u307E\u3067\u3067\u306F\u306A\u304B\u3063\u305F\u3093\u3060\u304C\u2026\u2026\u3002"
  - function: ShowCastMessage
    args:
    - "\u30A2\u30BA\u30DE"
    - "\u304F\u3063\u2026\u2026\u3063\u3066\u3053\u3068\u306F\u3001\n\u3084\u3063\u3071\u308A\u30AA\u30EC\u304C\u672A\u719F\u306A\u306E\u304B\uFF1F"
  - function: ShowCastMessage
    args:
    - "\u30C6\u30F3"
    - "\u3044\u3084\u3001\u304D\u3063\u3068\u305D\u3046\u3067\u306F\u306A\u3044\u3002\n\u541B\u306F\u9B54\u6CD5\u306E\u5236\u5FA1\u306B\u5341\u5206\u306A\u529B\u91CF\u304C\u3042\u308B\u3002"
  - function: ShowCastMessage
    args:
    - "\u30C6\u30F3"
    - "\u304A\u305D\u3089\u304F\u5225\u306E\u8981\u56E0\u2026\u2026\u3002\n\u4FFA\u306B\u3082\u5206\u304B\u3063\u3066\u3044\u306A\u3044\u4F55\u304B\u304C\u3042\u308B\u306F\u305A\u3002"
  - function: ShowCastMessage
    args:
    - "\u30A2\u30BA\u30DE"
    - "\u30AA\u30EC\u3001\u96E3\u3057\u3044\u3053\u3068\u306F\u5206\u304B\u3089\u306A\u3044\u3093\u3060\u3051\u3069\u3001\n\u5236\u5FA1\u4E0D\u53EF\u306E\u539F\u56E0\u304C\u3042\u308B\u306A\u3089\u77E5\u308A\u305F\u3044\u2026\u2026\uFF01"
  - function: ShowCastMessage
    args:
    - "\u30A2\u30BA\u30DE"
    - "\u8AB0\u304B\u3001\u305D\u3046\u3044\u3046\u306E\u306B\u8A73\u3057\u3044\u30E4\u30C4\u3068\u304B\n\u5C45\u305F\u308A\u3057\u306A\u3044\u306E\u304B\uFF1F"
  - function: ShowCastMessage
    args:
    - "\u30C6\u30F3"
    - "\u2026\u2026\u4E00\u4EBA\u3001\u4FFA\u3088\u308A\u3082\u30BB\u30AB\u30A4\u306E\u4ED5\u7D44\u307F\u306B\u8A73\u3057\u3044\n\u98DB\u3073\u5207\u308A\u8CE2\u3044\u4EBA\u9593\u304C\u5C45\u308B\u3002\u5C45\u308B\u304C\u2026\u2026\u3002"
  - function: ShowCastMessage
    args:
    - "\u30A2\u30BA\u30DE"
    - "\u5C45\u308B\u304C\uFF1F"
  - function: ShowCastMessage
    args:
    - "\u30C6\u30F3"
    - "\u5C11\u3005\u766A\u3067\u2026\u2026\u3001\u3044\u3084\u3001\u79C1\u60C5\u306F\u826F\u304F\u306A\u3044\u306A\u3002\n\u4ECA\u304B\u3089\u8A0A\u306D\u306B\u884C\u3053\u3046\u3002"
  - function: ShowCastMessage
    args:
    - "\u30C6\u30F3"
    - "\u3053\u306E\u4E8B\u5909\u306E\u89E3\u6C7A\u3068\u3068\u3082\u306B\u7A76\u660E\u3092\u3059\u308B\u3053\u3068\u3092\n\u7D04\u675F\u3059\u308B\u3088\u3002\u5F85\u3063\u3066\u3044\u3066\u304F\u308C\u3002"
